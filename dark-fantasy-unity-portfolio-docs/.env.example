# Complete environment template for The Cursed Biomes Portfolio.
# Copy this file to `.env.local` for local development or `.env.production` for deploy.
# Do not commit real secrets.

# Runtime
# NODE_ENV: development for local, production for deploy.
NODE_ENV=development
# HOST: 127.0.0.1 for local only. Use 0.0.0.0 on Railway/Render/VPS.
HOST=127.0.0.1
# PORT: local server port.
PORT=3001

# Public site links
# NEXT_PUBLIC_SITE_URL: final public domain, for example https://your-domain.com.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_GITHUB_USERNAME: GitHub username used by repo sync.
NEXT_PUBLIC_GITHUB_USERNAME=PiupiuTenshi
# NEXT_PUBLIC_ZALO_URL: public Zalo link shown in Contact.
NEXT_PUBLIC_ZALO_URL=https://zalo.me/0898087507
# NEXT_PUBLIC_FACEBOOK_URL: public Facebook profile link.
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/MahiruShiina.tym.1207
# NEXT_PUBLIC_MESSENGER_URL: public Messenger link opened by Contact and chatbot quick reply.
NEXT_PUBLIC_MESSENGER_URL=https://m.me/MahiruShiina.tym.1207
# NEXT_PUBLIC_CV_URL: public CV path.
NEXT_PUBLIC_CV_URL=/public/cv/Pham-Minh-Sang-Unity-Developer-CV.pdf

# Admin gate
# ADMIN_GATE_PHRASE: secret phrase used in chat command `/open gate: ...`.
ADMIN_GATE_PHRASE=moonlit-biomes
# ADMIN_PASSWORD: local fallback password. For production prefer ADMIN_PASSWORD_SHA256.
ADMIN_PASSWORD=admin123
# ADMIN_PASSWORD_SHA256: production password hash. Generate with:
# node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
ADMIN_PASSWORD_SHA256=
# ADMIN_JWT_SECRET: legacy/future compatibility secret; use a long random string if enabled later.
ADMIN_JWT_SECRET=change-this-long-random-secret

# Data and integrations
# DATABASE_URL: optional future DB connection. Current local phase stores JSON in /data.
DATABASE_URL=
# GITHUB_TOKEN: optional GitHub token to reduce rate limits. Leave empty for public API.
GITHUB_TOKEN=
# IP_GEO_PROVIDER_KEY: optional future IP geolocation provider key.
IP_GEO_PROVIDER_KEY=

# Contact notifications
# MESSENGER_WEBHOOK_URL: optional webhook bridge for Messenger/Page/n8n/Make.
# Facebook personal profiles cannot receive direct server push from a profile URL only.
MESSENGER_WEBHOOK_URL=
# ZALO_WEBHOOK_URL: optional webhook bridge to Zalo OA, n8n, Make, or your own notifier.
# Zalo personal accounts do not support simple direct-message API by phone number.
ZALO_WEBHOOK_URL=
# ZALO_OA_TOKEN: reserved for Zalo Official Account integration if you build the bridge.
ZALO_OA_TOKEN=
# TELEGRAM_*: optional future Telegram notifier placeholders.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email notifications via SMTP. Leave these blank if you only want Messenger/webhook notifications.
# NOTIFY_EMAIL_TO: where new contact messages should be sent. Supports comma-separated emails.
NOTIFY_EMAIL_TO=
# NOTIFY_EMAIL_FROM: sender address accepted by your SMTP provider.
NOTIFY_EMAIL_FROM=
# SMTP_HOST: for Gmail use smtp.gmail.com. For domain mail use your provider host.
SMTP_HOST=
# SMTP_PORT: 587 for STARTTLS, 465 for SSL/TLS.
SMTP_PORT=587
# SMTP_SECURE: true for port 465, false for port 587.
SMTP_SECURE=false
# SMTP_USER: SMTP login, often your email address.
SMTP_USER=
# SMTP_PASS: SMTP password or Gmail app password.
SMTP_PASS=
# NOTIFICATION_TIMEOUT_MS: max time to wait for email/webhook before continuing.
NOTIFICATION_TIMEOUT_MS=8000

# Local JSON retention limits
# These keep local JSON files from growing forever under traffic.
MAX_STORED_MESSAGES=2000
MAX_STORED_EVENTS=5000
MAX_STORED_AUDIT=2000
